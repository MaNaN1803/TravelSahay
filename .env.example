# Copy to .env and fill in. .env is gitignored.

# RapidAPI — Travel Advisor (apidojo). https://rapidapi.com/apidojo/api/travel-advisor
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=travel-advisor.p.rapidapi.com

# Google Maps Platform — enable Places API + Maps SDK (Android/iOS).
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Backend API base URL (the deployed Render URL, or localhost for dev).
EXPO_PUBLIC_API_URL=http://localhost:4000
